From f4f2e523daffe2ace709477dda1959126d1eb9fb Mon Sep 17 00:00:00 2001
From: Derek <derek@hyperi.io>
Date: Wed, 25 Mar 2026 11:56:48 +1100
Subject: [PATCH 3/4] rdp: Wire max-framerate through all settings subclasses

Bind max-framerate in user, headless, system, and handover settings.
User and headless read from gsettings. System reads from key-file
config. Handover binds from the common RDP gsettings schema.
---
 src/grd-settings-handover.c | 34 ++++++++++++++++++++++++++++++++++
 src/grd-settings-headless.c |  3 +++
 src/grd-settings-system.c   |  1 +
 src/grd-settings-user.c     |  3 +++
 4 files changed, 41 insertions(+)

diff --git a/src/grd-settings-handover.c b/src/grd-settings-handover.c
index 2fa8bc1..b33fdb0 100644
--- a/src/grd-settings-handover.c
+++ b/src/grd-settings-handover.c
@@ -22,9 +22,15 @@
 
 #include "grd-settings-handover.h"
 
+#include <gio/gio.h>
+
+#define GRD_RDP_COMMON_SCHEMA_ID "org.gnome.desktop.remote-desktop.rdp"
+
 struct _GrdSettingsHandover
 {
   GrdSettings parent;
+
+  GSettings *common_rdp_settings;
 };
 
 G_DEFINE_TYPE (GrdSettingsHandover, grd_settings_handover, GRD_TYPE_SETTINGS)
@@ -40,12 +46,40 @@ grd_settings_handover_new (void)
                        NULL);
 }
 
+static void
+grd_settings_handover_constructed (GObject *object)
+{
+  GrdSettingsHandover *settings = GRD_SETTINGS_HANDOVER (object);
+
+  g_settings_bind (settings->common_rdp_settings, "max-framerate",
+                   settings, "rdp-max-framerate",
+                   G_SETTINGS_BIND_DEFAULT);
+
+  G_OBJECT_CLASS (grd_settings_handover_parent_class)->constructed (object);
+}
+
+static void
+grd_settings_handover_finalize (GObject *object)
+{
+  GrdSettingsHandover *settings = GRD_SETTINGS_HANDOVER (object);
+
+  g_clear_object (&settings->common_rdp_settings);
+
+  G_OBJECT_CLASS (grd_settings_handover_parent_class)->finalize (object);
+}
+
 static void
 grd_settings_handover_init (GrdSettingsHandover *settings_handover)
 {
+  settings_handover->common_rdp_settings =
+    g_settings_new (GRD_RDP_COMMON_SCHEMA_ID);
 }
 
 static void
 grd_settings_handover_class_init (GrdSettingsHandoverClass *klass)
 {
+  GObjectClass *object_class = G_OBJECT_CLASS (klass);
+
+  object_class->constructed = grd_settings_handover_constructed;
+  object_class->finalize = grd_settings_handover_finalize;
 }
diff --git a/src/grd-settings-headless.c b/src/grd-settings-headless.c
index 50e641e..5c740d2 100644
--- a/src/grd-settings-headless.c
+++ b/src/grd-settings-headless.c
@@ -89,6 +89,9 @@ grd_settings_headless_constructed (GObject *object)
   g_settings_bind (settings->vnc_settings, "negotiate-port",
                    settings, "vnc-negotiate-port",
                    G_SETTINGS_BIND_DEFAULT);
+  g_settings_bind (settings->rdp_settings, "max-framerate",
+                   settings, "rdp-max-framerate",
+                   G_SETTINGS_BIND_DEFAULT);
 
   G_OBJECT_CLASS (grd_settings_headless_parent_class)->constructed (object);
 }
diff --git a/src/grd-settings-system.c b/src/grd-settings-system.c
index 531732a..1f5383f 100644
--- a/src/grd-settings-system.c
+++ b/src/grd-settings-system.c
@@ -475,6 +475,7 @@ static const FileSetting rdp_file_settings[] =
   { "tls-cert", "rdp-server-cert-path", read_filename, write_string },
   { "tls-key", "rdp-server-key-path", read_filename, write_string },
   { "port", "rdp-port", read_int, write_int },
+  { "max-framerate", "rdp-max-framerate", read_int, write_int },
 };
 
 static void
diff --git a/src/grd-settings-user.c b/src/grd-settings-user.c
index e8412a9..fb759c1 100644
--- a/src/grd-settings-user.c
+++ b/src/grd-settings-user.c
@@ -79,6 +79,9 @@ grd_settings_user_constructed (GObject *object)
   g_settings_bind (settings->rdp_settings, "kerberos-keytab",
                    settings, "rdp-kerberos-keytab",
                    G_SETTINGS_BIND_DEFAULT);
+  g_settings_bind (settings->rdp_settings, "max-framerate",
+                   settings, "rdp-max-framerate",
+                   G_SETTINGS_BIND_DEFAULT);
   g_settings_bind (settings->vnc_settings, "enable",
                    settings, "vnc-enabled",
                    G_SETTINGS_BIND_DEFAULT);
